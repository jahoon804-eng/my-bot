name: Build APK
on: push
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.10'
      - run: pip install buildozer cython
      - run: buildozer android debug
      - uses: actions/upload-artifact@v4
        with:
          name: app-release
          path: bin/*.apk
